# .env.example – environment variables for OpenPincer development
# Copy this file to .env and fill in the values.
#
# Most configuration values belong in `config.yaml`. Sensitive secrets such as API keys and
# dashboard passwords should be placed in `secrets.yaml` (or set via the corresponding env vars).

# ---------------------------------------------------------------------------
# Core services (required)
# ---------------------------------------------------------------------------
# PostgreSQL connection string for the application database.
# Example: postgres://user:password@localhost:5432/openpincer
# This cannot be set via config.yaml, so leave uncommented.
DATABASE_URL="postgres://username:password@localhost:5432/openpincer"

# ---------------------------------------------------------------------------
# Telegram bot configuration (required)
# ---------------------------------------------------------------------------
# Bot token obtained from @BotFather. Required for the Telegram interface.
# This is a secret and should be placed in `secrets.yaml` (or set via the env var).
# TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"

# Optional settings – prefer configuring these in config.yaml instead of env vars.
# ---------------------------------------------------------------
# Restrict the bot to a single Telegram user ID. Set in config.yaml → telegram.ownerId
# TELEGRAM_OWNER_ID="123456789"

# Use long‑polling (true) or webhook mode (false). Set in config.yaml → telegram.useLongPolling
# TELEGRAM_USE_LONG_POLLING="true"

# Workspace directory (defaults to cwd). Set in config.yaml → agentWorkspace
# AGENT_WORKSPACE="/home/youruser/workspace"

# Primary LLM model. Prefer setting in config.yaml → llm.model
# LLM_MODEL="anthropic/claude-sonnet-4-5"

# Tool allowlist. Prefer setting in config.yaml → tools.allowlist
# TOOL_ALLOWLIST="*"

# Enable hybrid vector memory (RAG). Prefer setting in config.yaml → memory.enabled
# ENABLE_MEMORY="false"

# Dashboard password. Prefer setting in secrets.yaml → dashboard.password
# DASHBOARD_PASSWORD="your‑strong‑password"

# ---------------------------------------------------------------------------
# Qdrant vector database (required for RAG / hybrid memory)
# ---------------------------------------------------------------------------
# URL of your Qdrant instance. Defaults to http://localhost:6333 if not set.
# QDRANT_URL="http://localhost:6333"

# API key for Qdrant (required only when Qdrant is deployed with authentication enabled).
# QDRANT_API_KEY="YOUR_QDRANT_API_KEY"

# ---------------------------------------------------------------------------
# FastEmbed (local embeddings sidecar – required for RAG when not using OpenAI embeddings)
# ---------------------------------------------------------------------------
# URL of the FastEmbed service. When set, FastEmbed is used for embeddings instead of OpenAI.
# Matches the default port exposed by the fastembed service in docker-compose.yaml.
# FASTEMBED_URL="http://localhost:8000"

# ---------------------------------------------------------------------------
# Provider API keys – required for the chosen LLM provider(s).
# These can be placed in secrets.yaml under the appropriate section.
# ---------------------------------------------------------------------------
# Anthropic (claude) – required if using an anthropic model.
# ANTHROPIC_API_KEY="YOUR_ANTHROPIC_API_KEY"

# OpenAI – required for openai/* models.
# OPENAI_API_KEY="YOUR_OPENAI_API_KEY"

# Mistral – required for mistral/* models.
# MISTRAL_API_KEY="YOUR_MISTRAL_API_KEY"

# Google (Gemini) – required for google/* models.
# GOOGLE_API_KEY="YOUR_GOOGLE_API_KEY"

# MiniMax – required for minimax/* models.
# MINIMAX_API_KEY="YOUR_MINIMAX_API_KEY"

# ---------------------------------------------------------------------------
# Additional custom provider configuration can be added to secrets.yaml.
# See docs for details on custom providers.
# ---------------------------------------------------------------------------
